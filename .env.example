PROJECT_NAME=fraud_detection_system
DATASET_PATH=final_dataset.parquet
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_GROUP_ID=fraud-consumers
SPARK_APP_NAME=fraud_detection_system
PRODUCER_ROWS_PER_SECOND=10
PRODUCER_SEND_DELAY_SECONDS=0
PRODUCER_LOG_EVERY_N=1000
PRODUCER_DRY_RUN=false
# Alert sink — defaults to same broker/cluster as the main topic
ALERT_KAFKA_TOPIC=fraud_alerts
ALERT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Notification consumer group
ALERT_NOTIFICATION_GROUP_ID=fraud-alert-notifiers
# SMTP email delivery (leave NOTIFICATION_SMTP_HOST empty to disable)
NOTIFICATION_SMTP_HOST=
NOTIFICATION_SMTP_PORT=465
NOTIFICATION_SMTP_USERNAME=
NOTIFICATION_SMTP_PASSWORD=
NOTIFICATION_SMTP_SENDER=alerts@yourdomain.com
NOTIFICATION_SMTP_USE_TLS=true
NOTIFICATION_EMAIL_RECIPIENTS=oncall@yourdomain.com,soc@yourdomain.com
# HTTP webhook delivery — comma-separated URLs (leave empty to disable)
NOTIFICATION_WEBHOOK_URLS=
NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=10
# API server settings
API_DB_PATH=artifacts/fraud_alerts.db
API_HOST=0.0.0.0
API_PORT=8000
